{
  "manifest_version": 3,
  "name": "ReviewReply AI",
  "version": "1.0",
  "description": "Reply to Google reviews with AI directly from Google Business Manager.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://business.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://business.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
